{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yeelight.com/schemas/pro-app-builder/capability-coverage.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "catalogVersion", "rows"],
  "properties": {
    "schemaVersion": { "type": "integer", "enum": [1] },
    "catalogVersion": { "type": "string", "minLength": 1 },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["capabilityId", "fixtureIds", "apiHandlerIds", "probeIds", "testIds", "uiConsumer", "allowedStatuses"],
        "properties": {
          "capabilityId": { "type": "string", "minLength": 1 },
          "fixtureIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "apiHandlerIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "probeIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "testIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "uiConsumer": { "type": "string", "minLength": 1 },
          "allowedStatuses": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "enum": ["read-proven", "preview-proven", "write-proven", "read-only", "unsupported", "version-mismatch"] } }
        }
      }
    }
  }
}
