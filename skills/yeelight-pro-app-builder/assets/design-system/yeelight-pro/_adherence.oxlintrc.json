{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/feedback/**",
              "components/navigation/**",
              "components/overlay/**",
              "components/shell/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppNavigation'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|activeId|onNavigate|key|ref|className|style|children)$/]",
        "message": "<AppNavigation> doesn't accept that prop. Declared props: items, activeId, onNavigate."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppShell'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|navigation|status|children|key|ref|className|style)$/]",
        "message": "<AppShell> doesn't accept that prop. Declared props: title, navigation, status, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|disabled|busy|onClick|type|key|ref|className|style)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, disabled, busy, onClick, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|disabled|onClick|key|ref|className|style)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: label, children, disabled, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='InlineNotice'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|tone|action|key|ref|className|style)$/]",
        "message": "<InlineNotice> doesn't accept that prop. Declared props: title, children, tone, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='InlineNotice'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|error)$/]",
        "message": "<InlineNotice> tone must be one of 'info' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModalSurface'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|children|footer|onClose|closeLabel|key|ref|className|style)$/]",
        "message": "<ModalSurface> doesn't accept that prop. Declared props: open, title, children, footer, onClose, closeLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|key|ref|className|style)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: children, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|warning|error|offline|readonly|mismatch)$/]",
        "message": "<StatusBadge> tone must be one of 'success' | 'warning' | 'error' | 'offline' | 'readonly' | 'mismatch'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
