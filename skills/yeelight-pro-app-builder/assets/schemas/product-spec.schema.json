{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yeelight.com/schemas/product-spec-v3.json",
  "title": "Yeelight PRO ProductSpec v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "product", "target", "scope", "modules", "deviceFamilies", "theme", "runtime", "diagnostics"],
  "properties": {
    "schemaVersion": { "const": 3 },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "title", "locale"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "locale": { "const": "zh-CN" }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formFactor", "navigation", "density"],
      "properties": {
        "formFactor": { "enum": ["desktop", "tablet", "mobile", "wall"] },
        "navigation": { "enum": ["sidebar", "adaptive-rail", "bottom-tabs", "touch-rail"] },
        "density": { "enum": ["comfortable", "compact", "touch"] }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["homeIds", "roomNames", "includeAllRooms"],
      "properties": {
        "homeIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "roomNames": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "includeAllRooms": { "type": "boolean" }
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "options"],
        "properties": { "id": { "type": "string", "minLength": 1 }, "options": { "type": "object" } }
      }
    },
    "deviceFamilies": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pack", "palette", "mode"],
      "properties": {
        "pack": { "enum": ["daylight-minimal", "warm-residential", "obsidian-console", "installer-contrast"] },
        "palette": { "enum": ["teal-blue", "sunset-amber", "neutral-graphite", "forest-cyan"] },
        "mode": { "enum": ["light", "dark", "auto"] }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "dataMode", "bridgeMode"],
      "properties": { "contractVersion": { "const": "1.0" }, "dataMode": { "enum": ["live", "mock"] }, "bridgeMode": { "const": "local" } }
    },
    "diagnostics": { "type": "array", "items": { "type": "object" } }
  }
}
