{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yeelight.com/schemas/product-spec-v4.json",
  "title": "Yeelight PRO ProductSpec v4",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "product", "target", "scope", "modules", "deviceFamilies", "theme", "runtime", "diagnostics"],
  "properties": {
    "schemaVersion": { "const": 4 },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "title", "locale"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "locale": { "const": "zh-CN" }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formFactor", "navigation"],
      "properties": {
        "formFactor": { "enum": ["desktop", "tablet", "mobile", "wall"] },
        "navigation": { "enum": ["sidebar", "adaptive-rail", "bottom-tabs", "touch-rail"] }
      },
      "allOf": [
        { "if": { "properties": { "formFactor": { "const": "desktop" } } }, "then": { "properties": { "navigation": { "const": "sidebar" } } } },
        { "if": { "properties": { "formFactor": { "const": "tablet" } } }, "then": { "properties": { "navigation": { "const": "adaptive-rail" } } } },
        { "if": { "properties": { "formFactor": { "const": "mobile" } } }, "then": { "properties": { "navigation": { "const": "bottom-tabs" } } } },
        { "if": { "properties": { "formFactor": { "const": "wall" } } }, "then": { "properties": { "navigation": { "const": "touch-rail" } } } }
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["homeIds", "roomNames", "includeAllRooms"],
      "properties": {
        "homeIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "roomNames": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "includeAllRooms": { "type": "boolean" }
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "options"],
        "properties": { "id": { "type": "string", "minLength": 1 }, "options": { "type": "object" } }
      }
    },
    "deviceFamilies": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "theme": { "$ref": "theme-spec.schema.json" },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "dataMode", "bridgeMode"],
      "properties": {
        "contractVersion": { "const": "1.0" },
        "dataMode": { "enum": ["live", "mock"] },
        "bridgeMode": { "const": "local" }
      }
    },
    "diagnostics": { "type": "array", "items": { "type": "object" } }
  }
}
