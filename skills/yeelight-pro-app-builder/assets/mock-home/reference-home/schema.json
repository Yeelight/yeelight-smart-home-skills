{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yeelight.com/schemas/pro-app-builder/reference-home.schema.json",
  "type": "object",
  "required": ["schemaVersion", "id", "title", "home", "areas", "rooms", "devices", "groups", "scenes", "automations", "testScenarios"],
  "properties": {
    "schemaVersion": { "type": "integer", "enum": [1] },
    "id": { "type": "string", "enum": ["reference-home"] },
    "title": { "type": "string", "minLength": 1 },
    "home": { "type": "object", "required": ["id", "name"] },
    "areas": { "type": "array", "minItems": 4, "items": { "type": "object", "required": ["id", "name"] } },
    "rooms": { "type": "array", "minItems": 12, "items": { "type": "object", "required": ["id", "name", "areaId"] } },
    "devices": { "type": "array", "minItems": 40, "items": { "type": "object", "required": ["id", "family", "name", "roomId", "properties", "schemaProperties"] } },
    "groups": { "type": "array", "minItems": 8, "items": { "type": "object", "required": ["id", "name", "description", "icon", "roomId", "groupCapability", "groupCategory", "componentId", "deviceIds"] } },
    "scenes": { "type": "array", "minItems": 12, "items": { "type": "object", "required": ["id", "name", "description", "icon", "status", "editablePayload"] } },
    "automations": { "type": "array", "minItems": 12, "items": { "type": "object", "required": ["id", "name", "status", "equivalenceClass", "editablePayload"] } },
    "automationSupported": { "type": "array", "minItems": 4 },
    "automationSupportedV2": { "type": "array", "minItems": 2 },
    "testScenarios": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "target"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["endpoint-failure", "timeout", "malformed", "mismatch", "missing-property", "offline", "reset"] },
          "target": { "type": "string", "minLength": 1 },
          "status": { "type": "integer" },
          "delayMs": { "type": "integer" },
          "property": { "type": "string" }
        }
      }
    }
  }
}
