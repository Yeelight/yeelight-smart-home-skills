{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.yeelight.com/pro-app-builder/toolchain-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "id", "node", "npm", "lockfileVersion"],
  "properties": {
    "$schema": { "const": "./schema.json" },
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^node-web-[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "node": { "type": "string", "minLength": 1 },
    "npm": { "type": "string", "minLength": 1 },
    "lockfileVersion": { "const": 3 }
  }
}
